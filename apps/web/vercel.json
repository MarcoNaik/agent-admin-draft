{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "bun install",
  "buildCommand": "bun run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "0" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://app.struere.dev; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' https://*.struere.dev data:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.struere.dev https://*.clerk.dev https://clerk.struere.dev; frame-src https://app.struere.dev https://clerk.struere.dev https://*.clerk.accounts.dev; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests" }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://docs.struere.dev",
      "permanent": false
    },
    {
      "source": "/app",
      "destination": "https://app.struere.dev",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "https://app.struere.dev/sign-in",
      "permanent": false
    },
    {
      "source": "/signup",
      "destination": "https://app.struere.dev/sign-up",
      "permanent": false
    }
  ]
}
